<script src="https://fastly.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>

<div class="main-box">
    <div class="row1">
        <div class="image1">
            <img src="../images/Energy assets/override vctr.png" alt="row1-image1">

        </div>
        <div class="container">

            <div class="stepper-wrapper">
                <div class="stepper-item">
                    <a href="/Deshboard/Override" style="text-decoration: none;"><div class="step-counter hot">Hot</div></a>
                </div>
                <div class="stepper-item">
                    <a href="/Deshboard/OverrideWarm" style="text-decoration: none;"><div class="step-counter active">Warm<span class="material-symbols-outlined" id="check">check_circle</span></div></a>
                </div>
                <div class="stepper-item">
                    <a href="/Deshboard/OverrideCold" style="text-decoration: none;"><div class="step-counter cold">Cold</div></a>
                </div>
            </div>


        </div>

        <div class="report">
            <a href="#"><button class="report-button">Trends & Reports</button></a>
        </div>

    </div>



<div class="row2">
    <div class="row2-img">
        <div class="img1-header">
