    //#region search
    const inputElement = document.getElementById('seacrhtext');
    let searchaddressdata = [
        { name: 'BELMONTE APARTMENT',                 latitude: 28.440253, longitude: 77.100897 },
        { name: 'PVR Naraina',                        latitude: 28.633236, longitude: 77.138667 },
        { name: 'World Trade Park',                   latitude: 26.852988, longitude: 75.804667 },
        { name: 'Larsen & Toubro Limited',            latitude: 23.026675, longitude: 72.570168 },
        { name: 'Movie Time Cubic Mall',              latitude: 19.045545, longitude: 72.903297 },
        { name: 'Lal Imli Mill',                      latitude: 26.477199, longitude: 80.339335 },
        { name: 'Murugappa Polytechnic College',      latitude: 13.125777, longitude: 80.117415 },
        { name: 'Treasure Island Mall (TI Mall)',     latitude: 22.721674, longitude: 75.878636 },
        { name: 'R P Sharma Institute Of Technology', latitude: 25.604432, longitude: 85.048575 },
        { name: 'Pizza Express',                      latitude: 19.116288, longitude: 72.909122 },
    ];

    inputElement.addEventListener('input', function () {
        filterSearch(inputElement.value);
