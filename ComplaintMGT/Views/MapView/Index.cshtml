    filterSearch = (value) => {
        const searchResult = document.getElementById('searchresult');
        if (value.trim() === '') {
            searchResult.style.display = 'none';
            searchResult.innerHTML = '';
            return;
        }
        const filtered = searchaddressdata.filter(item =>
            item.name.toLowerCase().includes(value.toLowerCase())
        );
        if (filtered.length > 0) {
            let fragment = '';
            filtered.forEach(element => {
                fragment += `<li data-lat="${element.latitude}" data-lng="${element.longitude}" data-name="${element.name}">${element.name}</li>`;
            });
            searchResult.innerHTML = fragment;
            searchResult.style.display = 'block';
        } else {
            searchResult.style.display = 'none';
        }
    }

    document.getElementById('searchresult').addEventListener('click', function (e) {
        if (e.target.tagName === 'LI') {
            const lat  = parseFloat(e.target.getAttribute('data-lat'));
            const lng  = parseFloat(e.target.getAttribute('data-lng'));
            const name = e.target.getAttribute('data-name');
            searchzoom({ name: name, latitude: lat, longitude: lng });
            document.getElementById('seacrhtext').value = name;
            document.getElementById('searchresult').style.display = 'none';
        }
    });

    document.addEventListener('click', function (e) {
        const searchContainer = document.querySelector('.search-container');
        if (!searchContainer.contains(e.target)) {
            document.getElementById('searchresult').style.display = 'none';
        }
    });

    let markerSVG = '<svg xmlns="http://www.w3.org/2000/svg" width="36px" height="36px" viewBox="-4 0 36 36" version="1.1"><g id="Vivid.JS" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Vivid-Icons" transform="translate(-125.000000, -643.000000)"><g id="Icons" transform="translate(37.000000, 169.000000)"><g id="map-marker" transform="translate(78.000000, 468.000000)"><g transform="translate(10.000000, 6.000000)"><path d="M14,0 C21.732,0 28,5.641 28,12.6 C28,23.963 14,36 14,36 C14,36 0,24.064 0,12.6 C0,5.641 6.268,0 14,0 Z" id="Shape" fill="#667eea"></path><circle id="Oval" fill="#764ba2" fill-rule="nonzero" cx="14" cy="14" r="7"></circle></g></g></g></g></g></svg>';

    createMapMarker = (searchdata) => {
        return new ol.style.Style({
            image: new ol.style.Icon({
                anchor: [0.5, 36],
                anchorXUnits: 'fraction',
                anchorYUnits: 'pixels',
                opacity: 1,
                src: 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(markerSVG),
                scale: 1.2
            }),
            text: new ol.style.Text({
                text: searchdata.name,
                scale: 1.3,
                font: 'bold 12px Segoe UI, sans-serif',
                offsetX: 25,
                offsetY: -10,
                placement: 'point',
                textAlign: 'left',
                fill: new ol.style.Fill({ color: '#ffffff' }),
                backgroundFill: new ol.style.Fill({ color: '#667eea' }),
                padding: [8, 12, 8, 12],
            })
        });
    };

    searchzoom = (searchdata) => {
        let coordinates = ol.proj.transform(
            [searchdata.longitude, searchdata.latitude],
            'EPSG:4326', 'EPSG:3857'
        );
        map.getView().animate({ center: coordinates, zoom: 14, duration: 1000 });
        searchvectorSource.getSource().clear();
        let searchmarkerfeature = new ol.Feature({
            geometry: new ol.geom.Point(coordinates),
            name: searchdata.name
        });
        searchmarkerfeature.setStyle(createMapMarker(searchdata));
        searchvectorSource.getSource().addFeature(searchmarkerfeature);
        searchvectorSource.setVisible(true);
    }
    //#endregion

    document.querySelector('.main-box').addEventListener('click', function () {
        document.querySelectorAll('.navbar-collapse.show').forEach(d => d.classList.remove('show'));
        document.querySelectorAll('.nav-item.show').forEach(i => i.classList.remove('show'));
    });

    document.addEventListener('DOMContentLoaded', function () {
        const sidebarMenu = document.querySelector('.sidebar-menu');
        if (sidebarMenu) {
            sidebarMenu.classList.remove('active');
        }
    });
</script>
