    //#region layers
    loadBaseLayer = () => {
        const baseLayers = new ol.layer.Group({
            title: 'basemap',
            openInLayerSwitcher: true,
            layers: [
                new ol.layer.Tile({
                    title: 'street',
                    baseLayer: true,
                    type: "base",
                    visible: true,
                    source: new ol.source.XYZ({
                        url: "https://mt0.google.com/vt/lyrs=m&x={x}&y={y}&z={z}",
                        crossOrigin: "anonymous",
