    function measurementtool() {
        let drawUnit      = UnitSelectbox;
        let showSegments  = document.getElementById("ShowSegment").checked;
        let clearPrevious = document.getElementById("ClearPrevious").checked;

        const style_new = new ol.style.Style({
            fill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.2)" }),
            stroke: new ol.style.Stroke({ color: "#667eea", width: 3 }),
            image: new ol.style.Circle({
                radius: 6,
                stroke: new ol.style.Stroke({ color: "#667eea", width: 2 }),
                fill: new ol.style.Fill({ color: "white" }),
            }),
        });

        let labelStyle = new ol.style.Style({
            text: new ol.style.Text({
                font: "14px Segoe UI, sans-serif",
                fill: new ol.style.Fill({ color: "rgba(255, 255, 255, 1)" }),
                backgroundFill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.9)" }),
                padding: [5, 8, 5, 8],
                textBaseline: "bottom",
                offsetY: -15,
            }),
            image: new ol.style.RegularShape({
                radius: 8, points: 3, angle: Math.PI,
                displacement: [0, 10],
                fill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.9)" }),
            }),
        });

        const tipStyle = new ol.style.Style({
            text: new ol.style.Text({
                font: "12px Segoe UI, sans-serif",
                fill: new ol.style.Fill({ color: "rgba(255, 255, 255, 1)" }),
                backgroundFill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.9)" }),
                padding: [4, 8, 4, 8],
                textAlign: "left",
                offsetX: 15,
            }),
        });

        const modifyStyle = new ol.style.Style({
            image: new ol.style.Circle({
                radius: 6,
                stroke: new ol.style.Stroke({ color: "#764ba2", width: 2 }),
                fill: new ol.style.Fill({ color: "white" }),
            }),
            text: new ol.style.Text({
                text: "Drag to modify",
                font: "12px Segoe UI, sans-serif",
                fill: new ol.style.Fill({ color: "rgba(255, 255, 255, 1)" }),
                backgroundFill: new ol.style.Fill({ color: "rgba(118, 75, 162, 0.9)" }),
                padding: [4, 8, 4, 8],
                textAlign: "left",
                offsetX: 15,
            }),
        });

        const segmentStyle = new ol.style.Style({
            text: new ol.style.Text({
                font: "11px Segoe UI, sans-serif",
                fill: new ol.style.Fill({ color: "rgba(255, 255, 255, 1)" }),
                backgroundFill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.8)" }),
                padding: [3, 6, 3, 6],
                textBaseline: "bottom",
                offsetY: -12,
            }),
            image: new ol.style.RegularShape({
                radius: 5, points: 3, angle: Math.PI,
                displacement: [0, 8],
                fill: new ol.style.Fill({ color: "rgba(102, 126, 234, 0.8)" }),
            }),
        });

        const segmentStyles = [segmentStyle];

        const formatLength = function (line) {
            const length = ol.sphere.getLength(line, { projection: 'EPSG:3857' });
            if (drawUnit === "KM") {
                return length > 100
                    ? Math.round((length / 1000) * 100) / 100 + " km"
                    : Math.round(length * 100) / 100 + " m";
            }
            return Math.round(length * 100) / 100 + " m";
        };

        const formatArea = function (polygon) {
            const area = ol.sphere.getArea(polygon, { projection: 'EPSG:3857' });
            if (drawUnit === "KM") {
                return area > 10000
                    ? Math.round((area / 1000000) * 100) / 100 + " km²"
                    : Math.round(area * 100) / 100 + " m²";
            }
            return Math.round(area * 100) / 100 + " m²";
        };

        const modify = new ol.interaction.Modify({
            source: vectorSourceMeasure,
            style: modifyStyle,
        });

        let tipPoint;

        function styleFunction(feature, segments, drawType, tip) {
            let styles   = [style_new];
            let geometry = feature.getGeometry();
            let type     = geometry.getType();
            let point, label, line;

            if (!drawType || drawType === type) {
                if (type === "Polygon") {
                    point = geometry.getInteriorPoint();
                    label = formatArea(geometry);
                    line  = new ol.geom.LineString(geometry.getCoordinates()[0]);
                } else if (type === "LineString") {
                    point = new ol.geom.Point(geometry.getLastCoordinate());
                    label = formatLength(geometry);
                    line  = geometry;
                }
            }

            if (segments && line) {
                let count = 0;
                line.forEachSegment(function (a, b) {
                    const segment = new ol.geom.LineString([a, b]);
                    const label   = formatLength(segment);
                    if (segmentStyles.length - 1 < count) { segmentStyles.push(segmentStyle.clone()); }
                    const segmentPoint = new ol.geom.Point(segment.getCoordinateAt(0.5));
                    segmentStyles[count].setGeometry(segmentPoint);
                    segmentStyles[count].getText().setText(label);
                    styles.push(segmentStyles[count]);
                    count++;
                });
            }

            if (label) {
                labelStyle.setGeometry(point);
                labelStyle.getText().setText(label);
                styles.push(labelStyle);
            }

            if (tip && type === "Point" && !modify.getOverlay().getSource().getFeatures().length) {
                tipPoint = geometry;
                tipStyle.getText().setText(tip);
                styles.push(tipStyle);
            }

            return styles;
        }

        const vector = new ol.layer.Vector({
            source: vectorSourceMeasure,
            style: function (feature) { return styleFunction(feature, showSegments, typeSelect); }
        });

        map.addLayer(vector);
        map.addInteraction(modify);

        let drawType  = typeSelect;
        let idleTip   = "Click to start measuring";
        let tip       = idleTip;

        draw = new ol.interaction.Draw({
            source: vectorSourceMeasure,
            type: drawType === "Polygon" ? "Polygon" : "LineString",
            style: function (feature) { return styleFunction(feature, showSegments, drawType, tip); },
        });

        let activeTip = "Click to continue drawing";

        draw.on("drawstart", function () {
            if (clearPrevious) { vectorSourceMeasure.clear(); }
            modify.setActive(false);
            tip = activeTip;
        });

        draw.on("drawend", function () {
            modifyStyle.setGeometry(tipPoint);
            modify.setActive(true);
            map.once("pointermove", function () { modifyStyle.setGeometry(); });
            tip = idleTip;
        });

        modify.setActive(true);
        map.addInteraction(draw);
        draw.setActive(false);
    }
    //#endregion

    //#region device layer
    const loadDeviceLayer = () => {

        // ── SITE MODE ─────────────────────────────────────────────────────
        if (currentLayerMode === 'Site') {
            document.getElementById('map-loading').style.display = 'block';

            fetch('/api/MapView/GetMapSites')
                .then(response => {
                    if (!response.ok) throw new Error('API error: ' + response.status);
                    return response.json();
                })
                .then(sitedata => {
                    let siteFeatures = [];
                    sitedata.forEach((element, ind) => {
                        if (!element.Latitude || !element.Longitude) return;
                        if (element.Latitude == 0 || element.Longitude == 0) return;

                        const coordinates = ol.proj.transform(
                            [parseFloat(element.Longitude), parseFloat(element.Latitude)],
                            'EPSG:4326', 'EPSG:3857'
                        );

                        const siteFeature = new ol.Feature({
                            geometry : new ol.geom.Point(coordinates),
                            status   : (element.IsActive == true || element.IsActive == 'true' || element.IsActive == 'True' || element.IsActive == 1 || element.IsActive == '1') ? 'active' : 'deactive',
                            id       : element.SiteId,
                            city     : element.CityName,
                            zone     : element.ZoneName,
                            number   : element.SiteId,
                            name     : element.SiteName,
                            address  : element.Address
                        });

                        siteFeature.setId('device' + ind);
                        createDeviceStyle(siteFeature);
                        siteFeatures.push(siteFeature);
                    });

                    deviceVectorLayer.getSource().clear();
                    deviceVectorLayer.getSource().addFeatures(siteFeatures);
                    deviceVectorLayer.setVisible(true);
                })
                .catch(err => {
                    console.error('GetMapSites API Error:', err);
                    alert('Could not load site data.');
                })
                .finally(() => {
                    document.getElementById('map-loading').style.display = 'none';
                });

        // ── ASSETS MODE ───────────────────────────────────────────────────
        } else if (currentLayerMode === 'Assets') {
            document.getElementById('map-loading').style.display = 'block';

            fetch('/api/MapView/GetMapAssets')
                .then(response => {
                    if (!response.ok) throw new Error('API error: ' + response.status);
                    return response.json();
                })
                .then(assetdata => {
                    let assetFeatures = [];

                    assetdata.forEach((element, ind) => {
                        if (!element.Latitude || !element.Longitude) return;
                        if (element.Latitude == 0 || element.Longitude == 0) return;

                        const coordinates = ol.proj.transform(
                            [parseFloat(element.Longitude), parseFloat(element.Latitude)],
                            'EPSG:4326', 'EPSG:3857'
                        );

                        const assetFeature = new ol.Feature({
                            geometry  : new ol.geom.Point(coordinates),
                            status    : 'active',
                            id        : element.SiteId,
                            name      : element.SiteName,
                            number    : element.SiteId,
                            city      : element.CityName,
                            zone      : element.ZoneName,
                            assetList : element.AssetList
                        });

                        assetFeature.setId('device' + ind);
                        createDeviceStyle(assetFeature);
                        assetFeatures.push(assetFeature);
                    });

                    deviceVectorLayer.getSource().clear();
                    deviceVectorLayer.getSource().addFeatures(assetFeatures);
                    deviceVectorLayer.setVisible(true);
                })
                .catch(err => {
                    console.error('GetMapAssets API Error:', err);
                    alert('Could not load asset data.');
                })
                .finally(() => {
                    document.getElementById('map-loading').style.display = 'none';
                });

        // ── DEVICE MODE ───────────────────────────────────────────────────
        } else if (currentLayerMode === 'Device') {
            document.getElementById('map-loading').style.display = 'block';

            fetch('/api/MapView/GetMapDevices')
                .then(response => {
                    if (!response.ok) throw new Error('API error: ' + response.status);
                    return response.json();
                })
                .then(devicedata => {
                    let deviceFeatures = [];

                    devicedata.forEach((element, ind) => {
                        if (!element.Latitude || !element.Longitude) return;
                        if (element.Latitude == 0 || element.Longitude == 0) return;

                        const coordinates = ol.proj.transform(
                            [parseFloat(element.Longitude), parseFloat(element.Latitude)],
                            'EPSG:4326', 'EPSG:3857'
                        );

                        const deviceFeature = new ol.Feature({
                            geometry   : new ol.geom.Point(coordinates),
                            status     : 'active',
                            id         : element.SiteId,
                            name       : element.SiteName,
                            number     : element.SiteId,
                            city       : element.CityName,
                            zone       : element.ZoneName,
                            deviceList : element.DeviceList
                        });

                        deviceFeature.setId('device' + ind);
                        createDeviceStyle(deviceFeature);
                        deviceFeatures.push(deviceFeature);
                    });

                    deviceVectorLayer.getSource().clear();
                    deviceVectorLayer.getSource().addFeatures(deviceFeatures);
                    deviceVectorLayer.setVisible(true);
                })
                .catch(err => {
                    console.error('GetMapDevices API Error:', err);
                    alert('Could not load device data.');
                })
                .finally(() => {
                    document.getElementById('map-loading').style.display = 'none';
                });
        }
    };

    // ── ICON STYLE ────────────────────────────────────────────────────────
     const createDeviceStyle = (feature) => {
        let status = feature.get("status");

        const greenIconStyle = new ol.style.Style({
            image: new ol.style.Icon({
                anchor: [0.5, 36],
                anchorXUnits: 'fraction',
                anchorYUnits: 'pixels',
                opacity: 1,
                src: 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(devicegreenicon),
                scale: 1.1
            }),
        });

        const redIconStyle = new ol.style.Style({
            image: new ol.style.Icon({
                anchor: [0.5, 36],
                anchorXUnits: 'fraction',
                anchorYUnits: 'pixels',
                opacity: 1,
                src: 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(deviceredicon),
                scale: 1.1
            }),
        });

        if (status === 'active') {
            feature.setStyle(greenIconStyle);
        } else {
            feature.setStyle(redIconStyle);
        }
    };
