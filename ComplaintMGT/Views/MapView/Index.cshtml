
@{
    ViewData["Title"] = "Map - View";
    Layout = "_LayoutNew";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ol@v8.2.0/ol.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<link href="~/v2.0/mapview/css/map.css" rel="stylesheet" />
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    input:focus, textarea:focus, select:focus {
        outline: none;
        border-color: #667eea !important;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25) !important;
    }

    .main-box {
        background: #f8f9fa;
        min-height: 100vh;
        padding: 20px;
        position: relative;
        z-index: 1;
    }

    .header {
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        margin-bottom: 20px;
    }

    .mapbtn {
        background: white;
        color: #667eea;
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        font-size: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        transition: all 0.3s ease;
    }

        .mapbtn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
        }

    .headerbtnholder {
        display: flex;
        gap: 15px;
        align-items: center;
        background: rgba(255, 255, 255, 0.2);
        padding: 10px 20px;
        border-radius: 50px;
        backdrop-filter: blur(10px);
    }

    .headbtn {
        background: white;
        border: none;
        padding: 10px;
        border-radius: 20px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .headbtn:hover {
            background: #667eea;
            transform: translateY(-2px);
        }

            .headbtn:hover .btntextcolor {
                color: white !important;
            }

        .headbtn.active-mode {
            background: #667eea;
        }

            .headbtn.active-mode .btntextcolor {
                color: white !important;
            }

    .btntextcolor {
        color: #667eea;
        font-weight: 600;
        cursor: pointer;
    }

    .filterbtn {
        background: white;
        border: none;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

        .filterbtn:hover {
            transform: rotate(90deg);
            background: #667eea;
        }

        .filterbtn::before {
            content: "⚙";
            font-size: 24px;
            color: #667eea;
        }

        .filterbtn:hover::before {
            color: white;
        }

    .sidebar-panel {
        background: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        height: calc(100vh - 180px);
        overflow-y: auto;
        position: sticky;
        top: 20px;
        z-index: 1050;
    }

    .map-container {
        position: relative;
        height: calc(100vh - 180px);
    }

    .measurement-box {
        border: 2px solid #e0e0e0;
        padding: 20px;
        margin: 10px 0;
        border-radius: 15px;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    }

        .measurement-box label {
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
            display: block;
            font-size: 18px;
        }

        .measurement-box select {
            margin: 8px 0;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            width: 100%;
            transition: all 0.3s ease;
            background: white;
        }

            .measurement-box select:hover {
                border-color: #667eea;
            }

        .measurement-box .form-check {
            margin: 10px 0;
        }

        .measurement-box .form-check-label {
            font-size: 14px;
            font-weight: 500;
            color: #555;
        }

    .btn-secondary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 8px 20px !important;
        font-weight: 600 !important;
        transition: all 0.3s ease !important;
    }

        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4) !important;
        }

    .search-container {
        position: relative;
        margin: 20px 0;
    }

    .search-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background: white;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

        .search-input-wrapper:focus-within {
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.3);
        }

    #seacrhtext {
        width: 100%;
        border: none;
        padding: 12px 20px;
        font-size: 14px;
    }

    #button-addon2 {
        border: none;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 12px 20px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        #button-addon2 svg {
            fill: white;
        }

        #button-addon2:hover {
            opacity: 0.9;
        }

    #searchresult {
        list-style: none;
        padding: 0;
        margin: 0;
        max-height: 300px;
        overflow-y: auto;
        border: none;
        display: none;
        background: white;
        position: absolute;
        width: 100%;
        z-index: 1100;
        margin-top: 5px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

        #searchresult li {
            padding: 12px 20px;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }

            #searchresult li:first-child {
                border-top-left-radius: 15px;
                border-top-right-radius: 15px;
            }

            #searchresult li:last-child {
                border-bottom-left-radius: 15px;
                border-bottom-right-radius: 15px;
                border-bottom: none;
            }

            #searchresult li::before {
                content: "📍";
                margin-right: 10px;
                font-size: 16px;
            }

            #searchresult li:hover {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
            }

    .map-control-btn {
        border: none;
        border-radius: 12px;
        padding: 12px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        margin: 8px 0;
        background: white;
        width: 100%;
        font-weight: 600;
        color: #333;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .map-control-btn:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

        .map-control-btn i {
            font-size: 18px;
        }

    #map {
        width: 100%;
        height: 100%;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        overflow: hidden;
    }

    .ol-popup {
        position: absolute;
        background-color: white;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        padding: 0;
        border-radius: 15px;
        border: none;
        bottom: 12px;
        left: -50px;
        min-width: 320px;
        max-width: 380px;
        overflow: hidden;
    }

        .ol-popup:after, .ol-popup:before {
            top: 100%;
            border: solid transparent;
            content: " ";
            height: 0;
            width: 0;
            position: absolute;
            pointer-events: none;
        }

        .ol-popup:after {
            border-top-color: white;
            border-width: 10px;
            left: 48px;
            margin-left: -10px;
        }

        .ol-popup:before {
            border-top-color: white;
            border-width: 11px;
            left: 48px;
            margin-left: -11px;
        }

    .popup-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 20px;
        font-weight: 600;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .popup-content {
        padding: 20px;
        max-height: 400px;
        overflow-y: auto;
    }

    .popup-row {
        display: flex;
        align-items: flex-start;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 12px;
    }

        .popup-row:last-child {
            border-bottom: none;
        }

    .popup-label {
        font-weight: 600;
        color: #667eea;
        min-width: 75px;
        max-width: 75px;
        display: flex;
        align-items: flex-start;
        gap: 5px;
        padding-top: 2px;
        flex-shrink: 0;
        word-break: keep-all;
    }

    .popup-value {
        color: #333;
        font-weight: 500;
        line-height: 1.6;
        flex: 1;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .asset-list-value {
        color: #333;
        font-weight: 500;
        line-height: 2.2;
        flex: 1;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-active {
        background: #d4edda;
        color: #155724;
    }

    .status-inactive {
        background: #f8d7da;
        color: #721c24;
    }

    .ol-popup-closer {
        text-decoration: none;
        position: absolute;
        top: 10px;
        right: 15px;
        color: white;
        font-size: 20px;
        font-weight: bold;
        cursor: pointer;
        z-index: 1;
    }

        .ol-popup-closer:hover {
            opacity: 0.8;
        }

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        border-radius: 10px;
    }

    .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .modal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        border: none;
    }

    .modal-title {
        font-weight: 600;
    }

    #map-loading {
        display: none;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 9999;
        background: rgba(255,255,255,0.85);
        padding: 20px 30px;
        border-radius: 12px;
        font-weight: 600;
        color: #667eea;
        box-shadow: 0 5px 20px rgba(0,0,0,0.15);
        pointer-events: none;
    }

    @@media (max-width: 991px) {
        .sidebar-panel {
            position: relative;
            top: 0;
            margin-bottom: 20px;
            height: auto;
            max-height: 500px;
        }

        .map-container {
            height: 500px;
        }

        #map {
            height: 500px;
        }
    }

    @@media (max-width: 768px) {
        .headerbtnholder {
            flex-wrap: wrap;
            justify-content: center;
        }

        .header {
            padding: 15px;
        }

        .main-box {
            padding: 10px;
        }
    }
</style>

<div class='main-box'>
    <div class='col-12'>
        <div class="row">
            <div class='header'>
                <div class='headerholder' style="display:flex; justify-content: space-between; align-items: center;">
                    <div>
                        <button class="mapbtn"><i class="fas fa-map-marked-alt"></i> Map View</button>
                    </div>

                    <div class='headerbtnholder'>
                        <button class='headbtn' id="btn-Site" onclick="setLayerMode('Site'); loadDeviceLayer()">
                            <label class="btntextcolor"><i class="fas fa-building"></i> Site</label>
                        </button>

                        <button class='headbtn' id="btn-Device" onclick="setLayerMode('Device'); loadDeviceLayer()">
                            <label class="btntextcolor"><i class="fas fa-mobile-alt"></i> Device</label>
                        </button>

                        <button class='headbtn' id="btn-Assets" onclick="setLayerMode('Assets'); loadDeviceLayer()">
                            <label class="btntextcolor"><i class="fas fa-box"></i> Assets</label>
                        </button>
                    </div>

                    <div>
                        <button class='filterbtn' onclick="loadModel()"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class='col-12'>
        <div class="row">
            <div class="col-lg-3 col-md-4">
                <div class="sidebar-panel">
                    <div class="measurement-box">
                        <label><i class="fas fa-ruler-combined"></i> Measurement</label>
                        <select id="MeasurementSelectbox" onchange="typeSelectmeasur(this)">
                            <option value="LineString" id="lineStringId">📏 Line Distance</option>
                            <option value="Polygon" id="polygonId">📐 Area</option>
                        </select>
                        <select id="UnitSelectbox" onchange="typeUniteMeasur(this)">
                            <option value="KM">Kilometer (km)</option>
                            <option value="Metre">Meter (m)</option>
                        </select>

                        <div class='form-check'>
                            <input type='checkbox' class='form-check-input' id="ShowSegment" checked />
                            <label class='form-check-label' for="ShowSegment">Show Segment Lengths</label>
                        </div>
                        <div class='form-check'>
                            <input type='checkbox' class='form-check-input' id="ClearPrevious" checked />
                            <label class='form-check-label' for="ClearPrevious">Clear Previous Measure</label>
                        </div>

                        <div class='row mt-3'>
                            <div class="col-6">
                                <button id="startmesrment" type="button" style="display:block" class="btn btn-secondary btn-sm w-100" onclick="startMeasurment()">
                                    <i class="fas fa-play"></i> START
                                </button>
                                <button id="stopmesrment" style="display:none" type="button" class="btn btn-secondary btn-sm w-100" onclick="stopMeasurment()">
                                    <i class="fas fa-stop"></i> STOP
                                </button>
                            </div>
                            <div class="col-6">
                                <button id="clearmesrment" type="button" class="btn btn-secondary btn-sm w-100" onclick="clearMeasurment()">
                                    <i class="fas fa-eraser"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="search-container">
                        <div class="search-input-wrapper">
                            <input type="text" id="seacrhtext" placeholder="🔍 Search locations..." aria-label="Search">
                            <button type="button" id="button-addon2">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <ul id="searchresult"></ul>
                    </div>

                    <button onclick="loadStartDrag()" class="map-control-btn">
                        <i class="fas fa-hand-rock"></i> Drag & Zoom
                    </button>
                    <button onclick="changeMapType('Street')" class="map-control-btn">
                        <i class="fas fa-road"></i> Street Map
                    </button>
                    <button onclick="changeMapType('Satellite')" class="map-control-btn">
                        <i class="fas fa-satellite"></i> Satellite Map
                    </button>
                    <button onclick="changeMapType('Climate')" class="map-control-btn">
                        <i class="fas fa-cloud-sun"></i> Climate Map
                    </button>
                </div>
            </div>

            <div class="col-lg-9 col-md-8">
                <div class="map-container">
                    <div id="map"></div>
                    <div id="map-loading"><i class="fas fa-spinner fa-spin"></i> &nbsp; Loading...</div>
                    <div id="popup" class="ol-popup">
                        <a href="#" id="popup-closer" class="ol-popup-closer">×</a>
                        <div id="popup-content"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="filtermodel" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-filter"></i> Filters</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="nav flex-column">
                        <a class="nav-item nav-link" href="#">All Devices</a>
                        <a href="#" class="nav-item nav-link">Active Only</a>
                        <a href="#" class="nav-item nav-link">Inactive Only</a>
                        <a href="#" class="nav-item nav-link">By Zone</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/ol@v8.2.0/dist/ol.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    loadModel = () => {
        const modal = new bootstrap.Modal(document.getElementById('filtermodel'));
        modal.show();
    }

