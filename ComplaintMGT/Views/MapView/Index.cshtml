    //#region variable
    let draw;
    let DRAWING_ACTIVE = false;
    let currentLayerMode = 'Device';

    setLayerMode = (mode) => {
        currentLayerMode = mode;
        document.querySelectorAll('.headbtn').forEach(btn => btn.classList.remove('active-mode'));
        const activeBtn = document.getElementById('btn-' + mode);
        if (activeBtn) activeBtn.classList.add('active-mode');
